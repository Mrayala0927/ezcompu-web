<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --ez-navy: #1a1f5e;
  --ez-navy-deep: #0f1340;
  --ez-navy-light: #252b7a;
  --ez-red: #cc1f1f;
  --ez-red-bright: #e82929;
  --ez-red-dim: rgba(204,31,31,0.12);
  --ez-bg: #0b0d1a;
  --ez-bg2: #0f1222;
  --ez-card: #131828;
  --ez-card2: #181d30;
  --ez-border: rgba(255,255,255,0.07);
  --ez-border2: rgba(255,255,255,0.13);
  --ez-text: #e8eaf2;
  --ez-muted: #8892aa;
  --ez-subtle: #3d4460;
  --ez-gold: #e8a020;
  --ez-gold-dim: rgba(232,160,32,0.12);
  --font-display: 'Barlow Condensed', sans-serif;
  --font-body: 'Barlow', sans-serif;
}

html { scroll-behavior: smooth; }
body {
  background: var(--ez-bg);
  color: var(--ez-text);
  font-family: var(--font-body);
  font-size: 16px;
  line-height: 1.65;
  overflow-x: hidden;
}

/* ──────────────── NAV ──────────────── */
nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 200;
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 5vw; height: 70px;
  background: rgba(11,13,26,0.92);
  backdrop-filter: blur(18px);
  border-bottom: 1px solid rgba(26,31,94,0.6);
}
.nav-logo { display: flex; align-items: center; gap: 10px; text-decoration: none; }
.nav-logo img { height: 44px; width: auto; }
.nav-links { display: flex; gap: 2rem; list-style: none; }
.nav-links a {
  font-size: 0.88rem; font-weight: 500; letter-spacing: 0.03em;
  color: var(--ez-muted); text-decoration: none; transition: color 0.2s;
}
.nav-links a:hover { color: var(--ez-text); }
.nav-right { display: flex; align-items: center; gap: 1rem; }
.nav-social { display: flex; gap: 0.5rem; }
.nav-social a {
  width: 32px; height: 32px; border-radius: 6px;
  border: 1px solid var(--ez-border2); color: var(--ez-muted);
  display: flex; align-items: center; justify-content: center;
  text-decoration: none; font-size: 0.85rem; transition: all 0.2s;
}
.nav-social a:hover { border-color: var(--ez-red); color: var(--ez-red); }
.nav-cta {
  background: var(--ez-red); color: #fff;
  font-family: var(--font-display); font-weight: 700; font-size: 0.9rem;
  letter-spacing: 0.06em; text-transform: uppercase;
  padding: 0.55rem 1.4rem; border-radius: 6px; text-decoration: none;
  transition: background 0.2s, transform 0.15s;
}
.nav-cta:hover { background: var(--ez-red-bright); transform: translateY(-1px); }

/* ──────────────── HERO ──────────────── */
.hero {
  min-height: 100vh;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  text-align: center; padding: 130px 5vw 80px;
  position: relative; overflow: hidden;
}
.hero-bg {
  position: absolute; inset: 0; z-index: 0;
  background:
    radial-gradient(ellipse 80% 60% at 50% -10%, rgba(26,31,94,0.55) 0%, transparent 70%),
    radial-gradient(ellipse 50% 40% at 80% 80%, rgba(204,31,31,0.08) 0%, transparent 60%);
}
.hero-lines {
  position: absolute; inset: 0; z-index: 0;
  background-image:
    linear-gradient(rgba(26,31,94,0.15) 1px, transparent 1px),
    linear-gradient(90deg, rgba(26,31,94,0.15) 1px, transparent 1px);
  background-size: 60px 60px;
}
.hero-logo {
  position: relative; z-index: 1; margin-bottom: 2.5rem;
}
.hero-logo img { width: min(480px, 80vw); height: auto; filter: drop-shadow(0 0 40px rgba(26,31,94,0.8)); }
.hero-eyebrow {
  position: relative; z-index: 1;
  display: inline-flex; align-items: center; gap: 8px;
  font-size: 0.75rem; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase;
  color: var(--ez-gold); border: 1px solid rgba(232,160,32,0.35);
  padding: 0.3rem 1rem; border-radius: 100px; margin-bottom: 1.4rem;
}
.hero-eyebrow::before { content: ''; width: 5px; height: 5px; border-radius: 50%; background: var(--ez-gold); }
.hero-title {
  position: relative; z-index: 1;
  font-family: var(--font-display); font-size: clamp(3rem, 7vw, 6rem);
  font-weight: 800; line-height: 0.95; letter-spacing: -0.01em; text-transform: uppercase;
  margin-bottom: 1.2rem;
}
.hero-title .red { color: var(--ez-red); }
.hero-title .navy { color: #6a76d8; }
.hero-sub {
  position: relative; z-index: 1;
  font-size: clamp(1rem, 2vw, 1.18rem); font-weight: 300; color: var(--ez-muted);
  max-width: 600px; margin: 0 auto 2.8rem;
}
.hero-actions {
  position: relative; z-index: 1;
  display: flex; gap: 1rem; flex-wrap: wrap; justify-content: center;
}
.btn-red {
  background: var(--ez-red); color: #fff;
  font-family: var(--font-display); font-weight: 700; font-size: 1rem;
  letter-spacing: 0.06em; text-transform: uppercase;
  padding: 0.85rem 2.4rem; border-radius: 7px; text-decoration: none;
  display: inline-flex; align-items: center; gap: 8px;
  transition: background 0.2s, transform 0.15s;
}
.btn-red:hover { background: var(--ez-red-bright); transform: translateY(-2px); }
.btn-outline {
  background: transparent; color: var(--ez-text);
  font-family: var(--font-display); font-weight: 700; font-size: 1rem;
  letter-spacing: 0.06em; text-transform: uppercase;
  padding: 0.85rem 2.4rem; border-radius: 7px;
  border: 1px solid var(--ez-border2); text-decoration: none;
  transition: border-color 0.2s, color 0.2s;
}
.btn-outline:hover { border-color: var(--ez-red); color: var(--ez-red); }
.hero-badges {
  position: relative; z-index: 1;
  display: flex; gap: 0.6rem; flex-wrap: wrap; justify-content: center; margin-top: 2rem;
}
.hero-badge {
  font-size: 0.78rem; font-weight: 500;
  padding: 0.3rem 0.85rem; border-radius: 100px;
  border: 1px solid var(--ez-border2); color: var(--ez-muted);
}

/* ──────────────── STATS ──────────────── */
.stats-strip {
  display: flex; flex-wrap: wrap; justify-content: center;
  border-top: 1px solid var(--ez-border); border-bottom: 1px solid var(--ez-border);
  background: rgba(26,31,94,0.08);
}
.stat { flex: 1; min-width: 140px; text-align: center; padding: 2rem 1.5rem; border-right: 1px solid var(--ez-border); }
.stat:last-child { border-right: none; }
.stat-n {
  font-family: var(--font-display); font-size: 2.6rem; font-weight: 800;
  color: var(--ez-red); letter-spacing: -0.01em; line-height: 1;
}
.stat-l { font-size: 0.82rem; color: var(--ez-muted); margin-top: 0.3rem; letter-spacing: 0.04em; text-transform: uppercase; }

/* ──────────────── SECTION ──────────────── */
section { padding: 100px 5vw; }
.section-chip {
  display: inline-block; font-size: 0.73rem; font-weight: 700;
  letter-spacing: 0.14em; text-transform: uppercase;
  padding: 0.25rem 0.85rem; border-radius: 4px; margin-bottom: 1rem;
}
.chip-red { background: var(--ez-red-dim); color: var(--ez-red); }
.chip-navy { background: rgba(26,31,94,0.4); color: #8a94f0; }
.chip-gold { background: var(--ez-gold-dim); color: var(--ez-gold); }
.section-title {
  font-family: var(--font-display); font-size: clamp(2rem, 4.5vw, 3.2rem);
  font-weight: 800; letter-spacing: -0.01em; text-transform: uppercase; line-height: 1.05;
  margin-bottom: 0.9rem;
}
.section-sub { font-size: 1rem; color: var(--ez-muted); max-width: 520px; }
.sh { margin-bottom: 4rem; }

/* ──────────────── HARDWARE GRID ──────────────── */
.hw-grid {
  display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1.5px;
  background: var(--ez-border); border: 1px solid var(--ez-border); border-radius: 14px; overflow: hidden;
}
.hw-card {
  background: var(--ez-card); padding: 2.5rem 2rem;
  display: flex; flex-direction: column; gap: 0.9rem;
  transition: background 0.25s;
  position: relative; overflow: hidden;
}
.hw-card:hover { background: var(--ez-card2); }
.hw-card::after {
  content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;
  background: var(--ez-red); transform: scaleX(0); transition: transform 0.3s; transform-origin: left;
}
.hw-card:hover::after { transform: scaleX(1); }
.hw-ico {
  width: 48px; height: 48px; border-radius: 10px; background: rgba(204,31,31,0.1);
  display: flex; align-items: center; justify-content: center; font-size: 1.4rem;
}
.hw-card h3 { font-family: var(--font-display); font-size: 1.15rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.02em; }
.hw-card p { font-size: 0.88rem; color: var(--ez-muted); line-height: 1.65; }
.hw-tag {
  font-size: 0.72rem; font-weight: 600; letter-spacing: 0.06em;
  padding: 0.18rem 0.6rem; border-radius: 4px; width: fit-content;
  background: var(--ez-red-dim); color: var(--ez-red);
  text-transform: uppercase;
}

/* ──────────────── SOFTWARE CARDS ──────────────── */
.sw-grid {
  display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.2rem;
}
.sw-card {
  background: var(--ez-card); border: 1px solid var(--ez-border);
  border-radius: 14px; padding: 2.2rem 2rem;
  display: flex; flex-direction: column; gap: 1rem;
  transition: border-color 0.25s, transform 0.2s;
}
.sw-card:hover { border-color: var(--ez-navy-light); transform: translateY(-3px); }
.sw-header { display: flex; align-items: center; gap: 14px; }
.sw-icon-wrap {
  width: 52px; height: 52px; border-radius: 12px; flex-shrink: 0;
  display: flex; align-items: center; justify-content: center; font-size: 1.5rem;
}
.sw-icon-wrap.red { background: var(--ez-red-dim); }
.sw-icon-wrap.navy { background: rgba(26,31,94,0.4); }
.sw-icon-wrap.gold { background: var(--ez-gold-dim); }
.sw-name { font-family: var(--font-display); font-size: 1.3rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.03em; }
.sw-tagline { font-size: 0.78rem; color: var(--ez-muted); }
.sw-desc { font-size: 0.9rem; color: var(--ez-muted); line-height: 1.7; }
.sw-features { list-style: none; display: flex; flex-direction: column; gap: 0.45rem; }
.sw-features li { font-size: 0.87rem; color: var(--ez-muted); display: flex; align-items: center; gap: 10px; }
.sw-features li::before { content: ''; width: 5px; height: 5px; border-radius: 50%; flex-shrink: 0; background: var(--ez-red); }
.sw-badge {
  align-self: flex-start; font-size: 0.7rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase;
  padding: 0.22rem 0.7rem; border-radius: 4px;
}
.sw-badge.prod { background: rgba(46,200,100,0.12); color: #2ec864; }
.sw-badge.dev { background: rgba(77,158,255,0.12); color: #4d9eff; }
.sw-badge.new { background: var(--ez-gold-dim); color: var(--ez-gold); }

/* ──────────────── WEBDEV ──────────────── */
.wd-wrap {
  display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: center;
}
.wd-visual {
  background: var(--ez-card); border: 1px solid var(--ez-border);
  border-radius: 14px; padding: 0;
  overflow: hidden;
}
.wd-browser {
  background: #1a1f30; padding: 0.7rem 1rem;
  display: flex; align-items: center; gap: 0.5rem;
  border-bottom: 1px solid var(--ez-border);
}
.wd-dot { width: 10px; height: 10px; border-radius: 50%; }
.wd-body { padding: 1.5rem; display: flex; flex-direction: column; gap: 0.8rem; }
.wd-bar {
  height: 10px; border-radius: 5px; background: rgba(26,31,94,0.5);
}
.wd-bar.short { width: 40%; }
.wd-bar.med { width: 70%; }
.wd-bar.full { width: 100%; }
.wd-bar.red-accent { background: rgba(204,31,31,0.4); }
.wd-grid-mock {
  display: grid; grid-template-columns: 1fr 1fr; gap: 0.6rem; margin-top: 0.5rem;
}
.wd-block {
  background: rgba(26,31,94,0.3); border-radius: 6px; height: 60px;
}
.wd-block.accent { background: rgba(204,31,31,0.15); }
.wd-content .section-chip { margin-bottom: 0.8rem; }
.tech-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 1.5rem; }
.tech-tag {
  font-size: 0.78rem; font-weight: 500; letter-spacing: 0.03em;
  padding: 0.3rem 0.8rem; border-radius: 100px;
  border: 1px solid var(--ez-border2); color: var(--ez-muted);
  transition: all 0.2s;
}
.tech-tag:hover { border-color: #8a94f0; color: #8a94f0; }
.wd-services { list-style: none; display: flex; flex-direction: column; gap: 0.6rem; margin-top: 1.5rem; }
.wd-services li { font-size: 0.9rem; color: var(--ez-muted); display: flex; gap: 10px; align-items: center; }
.wd-services li::before { content: '▸'; color: var(--ez-red); font-size: 0.75rem; flex-shrink: 0; }

/* ──────────────── UBICACION ──────────────── */
.location-section { background: var(--ez-bg2); }
.loc-wrap { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: start; }
.map-frame {
  border-radius: 14px; overflow: hidden;
  border: 1px solid var(--ez-border); height: 380px;
}
.map-frame iframe { width: 100%; height: 100%; border: none; display: block; }
.loc-info { display: flex; flex-direction: column; gap: 1.5rem; }
.loc-item { display: flex; gap: 16px; align-items: flex-start; }
.loc-ico {
  width: 42px; height: 42px; border-radius: 8px; flex-shrink: 0;
  background: var(--ez-red-dim);
  display: flex; align-items: center; justify-content: center; font-size: 1.1rem;
}
.loc-item h4 {
  font-family: var(--font-display); font-size: 0.9rem; font-weight: 700;
  text-transform: uppercase; letter-spacing: 0.08em; color: var(--ez-red); margin-bottom: 0.2rem;
}
.loc-item p { font-size: 0.9rem; color: var(--ez-muted); line-height: 1.6; }
.reviews-strip {
  display: flex; gap: 1rem; flex-direction: column; margin-top: 1.5rem;
  padding: 1.5rem; background: var(--ez-card); border-radius: 12px;
  border: 1px solid var(--ez-border);
}
.stars { color: #ffc107; font-size: 1rem; letter-spacing: 2px; }
.review-text { font-size: 0.88rem; color: var(--ez-muted); font-style: italic; line-height: 1.6; }
.review-author { font-size: 0.8rem; color: var(--ez-subtle); margin-top: 0.3rem; }

/* ──────────────── REDES SOCIALES ──────────────── */
.social-section { background: var(--ez-navy-deep); }
.social-cards { display: flex; gap: 1.2rem; flex-wrap: wrap; justify-content: center; margin-top: 3rem; }
.social-card {
  flex: 1; min-width: 200px; max-width: 260px;
  background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);
  border-radius: 14px; padding: 2rem 1.8rem; text-align: center;
  display: flex; flex-direction: column; align-items: center; gap: 0.8rem;
  text-decoration: none; color: inherit;
  transition: border-color 0.25s, transform 0.2s;
}
.social-card:hover { transform: translateY(-4px); }
.social-card.fb:hover { border-color: #1877f2; }
.social-card.wa:hover { border-color: #25d366; }
.social-card.ig:hover { border-color: #e1306c; }
.social-card.yt:hover { border-color: #ff0000; }
.s-icon {
  width: 56px; height: 56px; border-radius: 14px;
  display: flex; align-items: center; justify-content: center; font-size: 1.6rem;
}
.s-icon.fb { background: rgba(24,119,242,0.15); }
.s-icon.wa { background: rgba(37,211,102,0.15); }
.s-icon.ig { background: rgba(225,48,108,0.12); }
.s-icon.yt { background: rgba(255,0,0,0.12); }
.s-name {
  font-family: var(--font-display); font-size: 1rem; font-weight: 700;
  text-transform: uppercase; letter-spacing: 0.06em;
}
.s-handle { font-size: 0.82rem; color: var(--ez-muted); }

/* ──────────────── CTA ──────────────── */
.cta-section {
  text-align: center; padding: 110px 5vw;
  background: linear-gradient(to bottom, var(--ez-bg), var(--ez-navy-deep));
  position: relative; overflow: hidden;
}
.cta-bg {
  position: absolute; bottom: -100px; left: 50%; transform: translateX(-50%);
  width: 700px; height: 500px;
  background: radial-gradient(ellipse, rgba(204,31,31,0.12) 0%, transparent 65%);
  pointer-events: none;
}
.cta-section .section-title { font-size: clamp(2.2rem, 5vw, 4rem); position: relative; z-index: 1; }
.cta-section .section-sub { margin: 0 auto 2.8rem; position: relative; z-index: 1; }
.cta-actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; position: relative; z-index: 1; }

/* ──────────────── FOOTER ──────────────── */
footer {
  background: var(--ez-bg); border-top: 1px solid var(--ez-border);
  padding: 3rem 5vw;
}
.footer-main {
  display: flex; gap: 3rem; flex-wrap: wrap;
  justify-content: space-between; margin-bottom: 2.5rem;
